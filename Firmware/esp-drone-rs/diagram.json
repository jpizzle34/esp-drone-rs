    ["d_m3:ANODE", "fet_m3:DRAIN", "green", []],
    ["motor_m3:V-", "fet_m3:DRAIN", "green", []],
    ["fet_m3:SOURCE", "esp:GND.2", "black", []],

    ["esp:26", "rg_m4:1", "gold", ["h0"]],
