{
  "rust-analyzer.server.path": "${env:HOME}/.rustup/toolchains/stable-x86_64-unknown-linux-gnu/bin/rust-analyzer",
  "rust-analyzer.cargo.target": "xtensa-esp32-espidf",
  "rust-analyzer.checkOnSave.allTargets": false,
  "rust-analyzer.cargo.features": [],
  "rust-analyzer.cargo.extraEnv": {
    "RUSTUP_TOOLCHAIN": "esp",
    "MCU": "esp32",
    "ESP_IDF_VERSION": "v5.5.3",
    "ESP_IDF_TOOLS_INSTALL_DIR": "workspace"
  },
  "rust-analyzer.cargo.extraArgs": [
    "-Zbuild-std=std,panic_abort"
  ],
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "target": "xtensa-esp32-espidf",
          "features": [],
          "extraEnv": {
            "RUSTUP_TOOLCHAIN": "esp",
            "MCU": "esp32",
            "ESP_IDF_VERSION": "v5.5.3",
            "ESP_IDF_TOOLS_INSTALL_DIR": "workspace"
          },
          "extraArgs": [
            "-Zbuild-std=std,panic_abort"
          ]
        },
        "checkOnSave": {
          "allTargets": false
        }
      }
    }
  }
}
