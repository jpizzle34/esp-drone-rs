{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build firmware (release)",
      "type": "shell",
      "command": "${workspaceFolder}/Firmware/esp-drone-rs/scripts/build.sh",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Build firmware (debug)",
      "type": "shell",
      "command": "${workspaceFolder}/Firmware/esp-drone-rs/scripts/build.sh debug",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Flash firmware (release)",
      "type": "shell",
      "command": "${workspaceFolder}/Firmware/esp-drone-rs/scripts/flash.sh",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Flash firmware (debug)",
      "type": "shell",
      "command": "${workspaceFolder}/Firmware/esp-drone-rs/scripts/flash.sh debug",
      "problemMatcher": ["$rustc"]
    },
    {
      "label": "Build for Wokwi",
      "type": "shell",
      "command": "${workspaceFolder}/Firmware/esp-drone-rs/scripts/build-for-wokwi.sh",
      "problemMatcher": ["$rustc"]
    }
  ]
}
